    {
      "query_title": "questionnaire_1",
      "ranking_type": "form",
      "description": "You're about to start the experiment, but first, this part is dedicated to collect your demographic data in order to cluster the responses of each participant in the research. <br><br>Demographics will be important for the following survey. Please indicate as honestly as you can your data in the questions included below.  Please be aware that to prevent random responses we use attention checks. <br><br>Thank you for your participation. <br><br>",
      "show_xai": false,
      "questionnaire": [
        {
          "question": "1) What is your gender?",
          "field": "gender",
          "options": [
            "Female",
            "Male",
            "Non-binary",
            "Prefer not to say"
          ],
          "mandatory": true
        },
        {
          "question": "2) What is your age range?",
          "field": "age",
          "options": [
            "18-24",
            "25-34",
            "35-44",
            "45-54",
            "55-64",
            "65+"
          ],
          "mandatory": true
        },
        {
          "question": "3) What is your country of residence?",
          "field": "country_residence",
          "options": "text",
          "mandatory": true
        },
        {
          "question": "4) Please describe your previous experiences with AI-based hiring systems.",
          "field": "experience_ai_ranking",
          "options": "text",
          "mandatory": false
        },
        {
          "question": "5) How familiar are you with artificial intelligence (AI) technologies?",
          "field": "familiarity_ai",
          "options": "likert-7",
          "mandatory": true
        },
        {
          "question": "6) Is the sky blue?",
          "field": "attention_blue_sky",
          "options":["yes", "no"],
          "mandatory": true,
          "correct_answer": "yes"
        }
      ]
    },
